      - "\u30BF\u30C3\u30D7\u3067\u30BA\u30FC\u30E0\u753B\u9762\u3078"
      - "\uD0ED\uC73C\uB85C \uC90C \uD654\uBA74\uC73C\uB85C"
      - "\u70B9\u51FB\u53EF\u7F29\u653E\u5C4F\u5E55"
      - "\u9EDE\u64CA\u53EF\u7E2E\u653E\u87A2\u5E55"
      - "\u041D\u0430\u0436\u043C\u0438\u0442\u0435, \u0447\u0442\u043E\u0431\u044B
        \u0443\u0432\u0435\u043B\u0438\u0447\u0438\u0442\u044C \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435."
