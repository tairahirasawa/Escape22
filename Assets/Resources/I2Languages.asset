    - Term: Message/stage_000_opening_g_02
      TermType: 0
      Description: 
      Languages:
      - 'No, I don''t have one...


'
      - "\u3044\u3084\u3001\u3001\u3082\u3063\u3066\u306D\u3047\u3001\u3001\u3001\u3002\n"
      - "\uC544\uB2C8,, \uC548\uB3FC,,,.\n"
      - "\u4E0D\uFF0C\u6211\u6CA1\u6709\u2026\u2026\n\n"
      - "\u4E0D\uFF0C\u6211\u6C92\u6709\u2026"
      - "\u041D\u0435\u0442, \u0443 \u043C\u0435\u043D\u044F \u0435\u0433\u043E \u043D\u0435\u0442...\n\n"
